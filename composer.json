{
    "name": "iqv/qliro_php_sdk",
    "description": "PHP SDK for the Qliro payment API",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.12",
        "phpstan/phpstan-phpunit": "^1.4"
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse"
    },
    "autoload": {
        "psr-4": {
            "Qliro\\": "src/Qliro/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Qliro\\Tests\\": "tests/"
        }
    }
}
